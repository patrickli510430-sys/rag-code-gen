# ==========================================
#  RAG Code Gen 配置文件
#  复制此文件为 .env 并填入你的配置
# ==========================================

# --- LLM 配置 (支持任何 OpenAI 兼容 API) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# --- 嵌入模型 ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# --- 爬虫 ---
CRAWLER_MAX_PAGES=50
CRAWLER_TIMEOUT=30

# --- 沙箱 ---
VALIDATOR_SANDBOX_TIMEOUT=10

# --- 服务 ---
API_HOST=0.0.0.0
API_PORT=8000
